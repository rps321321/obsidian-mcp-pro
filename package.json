{
  "name": "obsidian-mcp-pro",
  "version": "1.8.1",
  "description": "The most feature-complete MCP server for Obsidian vaults — search, read, write, tag, link analysis, graph traversal, canvas support, and more.",
  "type": "module",
  "bin": {
    "obsidian-mcp-pro": "build/index.js"
  },
  "main": "./build/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node build/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "obsidian",
    "model-context-protocol",
    "ai",
    "claude",
    "llm",
    "knowledge-management",
    "notes",
    "markdown",
    "vault"
  ],
  "author": "rps321",
  "license": "MIT",
  "homepage": "https://github.com/rps321321/obsidian-mcp-pro#readme",
  "bugs": {
    "url": "https://github.com/rps321321/obsidian-mcp-pro/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rps321321/obsidian-mcp-pro.git"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.17.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "eslint": "^9.39.4",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.2",
    "vitest": "^3.0.0"
  }
}
